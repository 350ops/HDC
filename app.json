{
  "expo": {
    "newArchEnabled": true,
    "name": "HDC Sports",
    "slug": "hdc-sports",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "scheme": "hdc-sports",
    "experiments": {
      "tsconfigPaths": true
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID"
        }
      ],
      "expo-web-browser"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mv.com.hdc.sports",
      "usesAppleSignIn": true,
      "appleTeamId": "ANAZ4TXPX5"
    },
    "android": {
      "package": "mv.com.hdc.sports",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "config": {
        "enableOnBackInvokedCallback": false
      }
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "11853cd2-a6e3-4b02-8a81-29938150b8a1"
      }
    },
    "owner": "thomino",
    "updates": {
      "url": "https://u.expo.dev/11853cd2-a6e3-4b02-8a81-29938150b8a1"
    }
  }
}
